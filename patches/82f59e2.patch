From 82f59e20e67286cc3ef61cd1506f9e9da5e2ca6d Mon Sep 17 00:00:00 2001
From: spaceavenue <spaceavenue@proton.me>
Date: Wed, 10 Jun 2026 21:13:58 +0530
Subject: [PATCH] Add vertical centering for single windows in a column

---
 docs/wiki/Configuration:-Layout.md | 13 ++++++
 niri-config/src/layout.rs          |  5 +++
 niri-config/src/lib.rs             |  1 +
 src/layout/scrolling.rs            | 68 +++++++++++++++++++++++++++---
 src/layout/tests.rs                |  2 +
 5 files changed, 82 insertions(+), 7 deletions(-)

diff --git a/docs/wiki/Configuration:-Layout.md b/docs/wiki/Configuration:-Layout.md
index 5e5e2a5c6c..b0d04e545f 100644
--- a/docs/wiki/Configuration:-Layout.md
+++ b/docs/wiki/Configuration:-Layout.md
@@ -9,6 +9,7 @@ layout {
     gaps 16
     center-focused-column "never"
     always-center-single-column
+    center-single-window
     empty-workspace-above-first
     default-column-display "tabbed"
     background-color "#003300"
@@ -142,6 +143,18 @@ layout {
 }
 ```
 
+### `center-single-window`
+
+<sup>Since: next release</sup>
+
+If set, niri will vertically center single windows in columns.
+
+```kdl
+layout {
+    center-single-window
+}
+```
+
 ### `empty-workspace-above-first`
 
 <sup>Since: 25.01</sup>
