+#[test]
+fn portrait_fill_current_column_fills_until_overflow() {
+    let mut config = Config::default();
+    config.layout = niri_config::Layout::from_part(&niri_config::LayoutPart {
+        portrait_fill_current_column: Some(Flag(true)),
+        center_single_window: Some(Flag(true)),
+        gaps: Some(FloatOrInt(16.)),
+        ..Default::default()
+    });
+    let mut layout = Layout::new(Clock::with_time(Duration::ZERO), &config);
+
+    add_test_output(&mut layout, (1080, 1920));
+    add_half_height_window(&mut layout, 1);
+    assert_eq!(scrolling_positions(&layout), [(1, Some((1, 1)))]);
+    let first_y = layout
+        .active_workspace()
+        .unwrap()
+        .scrolling()
+        .tiles_with_render_positions()
+        .find(|(tile, _, _)| tile.window().id() == &1)
+        .unwrap()
+        .1
+        .y;
+    assert_eq!(first_y, 492.);
+
+    add_half_height_window(&mut layout, 2);
+    assert_eq!(
+        scrolling_positions(&layout),
+        [(1, Some((1, 1))), (2, Some((1, 2)))]
+    );
+
+    add_half_height_window(&mut layout, 3);
+    assert_eq!(
+        scrolling_positions(&layout),
+        [(1, Some((1, 1))), (2, Some((1, 2))), (3, Some((2, 1))),]
+    );
+    let overflow_y = layout
+        .active_workspace()
+        .unwrap()
+        .scrolling()
+        .tiles_with_render_positions()
+        .find(|(tile, _, _)| tile.window().id() == &3)
+        .unwrap()
+        .1
+        .y;
+    assert_eq!(overflow_y, 492.);
+}
+
+#[test]
+fn portrait_fill_current_column_keeps_landscape_insertion() {
+    let disabled_layout = niri_config::Layout::from_part(&niri_config::LayoutPart::default());
+    assert!(!disabled_layout.portrait_fill_current_column);
+
+    let mut config = Config::default();
+    config.layout = niri_config::Layout::from_part(&niri_config::LayoutPart {
+        portrait_fill_current_column: Some(Flag(true)),
+        gaps: Some(FloatOrInt(16.)),
+        ..Default::default()
+    });
+    let mut layout = Layout::new(Clock::with_time(Duration::ZERO), &config);
+
+    add_test_output(&mut layout, (1920, 1080));
+    add_half_height_window(&mut layout, 1);
+    add_half_height_window(&mut layout, 2);
+    add_half_height_window(&mut layout, 3);
+
+    assert_eq!(
+        scrolling_positions(&layout),
+        [(1, Some((1, 1))), (2, Some((2, 1))), (3, Some((3, 1))),]
+    );
+}
