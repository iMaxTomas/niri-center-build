+fn add_test_output(layout: &mut Layout<TestWindow>, size: (i32, i32)) {
+    let output = Output::new(
+        "output".to_owned(),
+        PhysicalProperties {
+            size: Size::from(size),
+            subpixel: Subpixel::Unknown,
+            make: String::new(),
+            model: String::new(),
+            serial_number: String::new(),
+        },
+    );
+    output.change_current_state(
+        Some(Mode {
+            size: Size::from(size),
+            refresh: 60000,
+        }),
+        None,
+        None,
+        None,
+    );
+    output.user_data().insert_if_missing(|| OutputName {
+        connector: "output".to_owned(),
+        make: None,
+        model: None,
+        serial: None,
+    });
+    layout.add_output(output, None);
+    layout.verify_invariants();
+}
+
+fn add_half_height_window(layout: &mut Layout<TestWindow>, id: usize) {
+    layout.add_window(
+        TestWindow::new(TestWindowParams::new(id)),
+        AddWindowTarget::Auto,
+        None,
+        Some(PresetSize::Proportion(0.5)),
+        false,
+        false,
+        ActivateWindow::default(),
+    );
+    layout.verify_invariants();
+    check_ops_on_layout(
+        layout,
+        [
+            Op::Communicate(id),
+            Op::AdvanceAnimations { msec_delta: 1000 },
+        ],
+    );
+}
