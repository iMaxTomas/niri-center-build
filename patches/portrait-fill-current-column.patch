+    /// Moves a newly added window into the immediately previous column when it fits vertically
+    /// on a portrait working area. Returns whether the window was moved.
+    pub fn try_portrait_fill_current_column(&mut self, window: &W::Id) -> bool {
+        if !self.options.layout.portrait_fill_current_column {
+            return false;
+        }
+
+        if self.working_area.size.h <= self.working_area.size.w {
+            return false;
+        }
+
+        let Some(source_col_idx) = self.columns.iter().position(|col| col.contains(window)) else {
+            return false;
+        };
+
+        let Some(dest_col_idx) = source_col_idx.checked_sub(1) else {
+            return false;
+        };
+
+        let source = &self.columns[source_col_idx];
+        let dest = &self.columns[dest_col_idx];
+
+        let column_is_eligible = |col: &Column<W>| {
+            col.display_mode == ColumnDisplay::Normal
+                && !col.is_full_width
+                && !col.is_pending_fullscreen
+                && !col.is_pending_maximized
+                && col.sizing_mode().is_normal()
+        };
+        if !column_is_eligible(source) || !column_is_eligible(dest) {
+            return false;
+        }
+
+        let source_tile_idx = source.position(window).unwrap();
+        let tile = &source.tiles[source_tile_idx];
+        if !tile.window().pending_sizing_mode().is_normal() {
+            return false;
+        }
+
+        // Equality fits: the incoming tile gets its own trailing gap after the move.
+        let gaps = self.options.layout.gaps;
+        let dest_tile_count_after_move = dest.tiles.len() + 1;
+        let mut needed = tile.tile_expected_or_current_size().h;
+        for dest_tile in &dest.tiles {
+            needed += dest_tile.tile_expected_or_current_size().h;
+        }
+        needed += (dest_tile_count_after_move + 1) as f64 * gaps;
+        if needed > self.working_area.size.h {
+            return false;
+        }
+
+        let saved_height = source.data[source_tile_idx].height;
+        let source_was_active = self.active_column_idx == source_col_idx;
+
+        let offset =
+            self.column_x(source_col_idx) + source.render_offset().x - self.column_x(dest_col_idx);
+        let mut offset = Point::from((offset, 0.));
+        let prev_off = source.tile_offset(source_tile_idx);
+
+        let removed = self.remove_tile(window, Transaction::new());
+
+        // If the source column was to the left of the destination, removing it shifts the
+        // destination index down by one.
+        let dest_col_idx = if source_col_idx < dest_col_idx {
+            dest_col_idx - 1
+        } else {
+            dest_col_idx
+        };
+
+        self.add_tile_to_column(dest_col_idx, None, removed.tile, source_was_active);
+
+        // add_tile_to_column() resets the moved height to auto; reapply the resolved height
+        // through the column setter, which keeps a single fixed-height window per column.
+        let dest = &mut self.columns[dest_col_idx];
+        let new_tile_idx = dest.tiles.len() - 1;
+        if let WindowHeight::Fixed(height) = saved_height {
+            dest.set_window_height(
+                SizeChange::SetFixed(height.round().clamp(1., 100000.) as i32),
+                Some(new_tile_idx),
+                false,
+            );
+        }
+
+        offset += prev_off - dest.tile_offset(new_tile_idx);
+        offset.x -= dest.render_offset().x;
+
+        let new_tile = &mut dest.tiles[new_tile_idx];
+        new_tile.animate_move_from(offset);
+
+        true
+    }
